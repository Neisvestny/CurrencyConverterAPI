{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2022"],
		"module": "commonjs",

		"rootDir": "./src",
		"outDir": "./dist",

		"strict": true,
		"esModuleInterop": true,

		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,

		"typeRoots": ["./src/types"]
	},
	"include": ["src"]
}
